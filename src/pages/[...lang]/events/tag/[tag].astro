---
import type { GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import { fetchEvents, getEventLanguageCodes, eventsListRobots } from '~/utils/events';
import { getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';
import config from '~/config/config.json';

type Props = {
  lang: string;
  tag: { slug: string; title: string };
};

export const prerender = true;

export const getStaticPaths = (async () => {
  const events = await fetchEvents();
  const defaultLang = config.settings.default_language;
  const defaultLangInSubdir = config.settings.default_language_in_subdir;

  const map = new Map<string, { lang: string; tag: { slug: string; title: string } }>();

  for (const event of events) {
    if (!Array.isArray(event.tags)) continue;
    const langs = getEventLanguageCodes(event);
    for (const t of event.tags) {
      for (const code of langs) {
        const key = `${code}|${t.slug}`;
        if (!map.has(key)) {
          map.set(key, {
            lang: code,
            tag: {
              slug: t.slug,
              title: t.title,
            },
          });
        }
      }
    }
  }

  return Array.from(map.values()).map((entry) => ({
    params: {
      lang: entry.lang === defaultLang && !defaultLangInSubdir ? undefined : entry.lang,
      tag: entry.tag.slug,
    },
    props: entry,
  }));
}) satisfies GetStaticPaths;

const { lang, tag } = Astro.props as Props;
const events = (await fetchEvents()).filter((event) => {
  const hasTag = Array.isArray(event.tags) && event.tags.some((t) => t.slug === tag.slug);
  if (!hasTag) return false;

  const eventLang = event.lang;
  if (Array.isArray(eventLang)) return eventLang.includes(lang);
  if (typeof eventLang === 'string') return eventLang === lang;
  return lang === config.settings.default_language;
});

const tagPath = `${lang === config.settings.default_language && !config.settings.default_language_in_subdir ? '' : `${lang}/`}events/tag/${tag.slug}`;

const metadata: MetaData = {
  title: `Events tagged ${tag.title}`,
  description: `Browse events tagged ${tag.title}.`,
  canonical: String(new URL(getPermalink(tagPath, 'page'), Astro.site ?? 'https://capitollawpartners.com')),
  robots: {
    index: eventsListRobots.index,
    follow: eventsListRobots.follow,
  },
};
---

<Layout metadata={metadata}>
  <section class="py-8 sm:py-16 lg:py-20 mx-auto max-w-4xl px-4 sm:px-6">
    <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading mb-6">{tag.title}</h1>
    <BlogList posts={events} lang={lang} taxonomyBasePath="events" />
  </section>
</Layout>
