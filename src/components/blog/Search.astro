---
export interface SearchCopy {
  title?: string;
  label: string;
  placeholder: string;
  helper: string;
  loading: string;
  error: string;
  clear: string;
  resultsLabelOne: string;
  resultsLabelMany: string;
  noResults: string;
}

export interface Props {
  lang?: string;
  searchIndexUrl: string;
  copy: SearchCopy;
}

const { lang = 'en', searchIndexUrl, copy } = Astro.props;

const localeByLanguage = {
  en: 'en-US',
  tr: 'tr-TR',
  es: 'es-ES',
  pt: 'pt-PT',
  fr: 'fr-FR',
} as const;

const dateLocale = localeByLanguage[lang as keyof typeof localeByLanguage] ?? localeByLanguage.en;
---

<div
  data-blog-search-root
  data-lang={lang}
  data-date-locale={dateLocale}
  data-search-index-url={searchIndexUrl}
  data-copy={JSON.stringify(copy)}
>
  <div class="mb-8 sm:mb-10">
    <div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm sm:p-5">
      <label class="mb-2 block text-sm font-semibold text-gray-900" for="blog-search-input">{copy.label}</label>
      <div
        class="flex items-center gap-3 rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 focus-within:border-gray-300 focus-within:bg-white"
      >
        <svg
          aria-hidden="true"
          class="h-5 w-5 flex-none text-gray-500"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
        <input
          id="blog-search-input"
          type="search"
          class="min-w-0 flex-1 border-0 bg-transparent p-0 text-base text-gray-900 placeholder:text-gray-500 focus:outline-none focus:ring-0"
          placeholder={copy.placeholder}
          autocomplete="off"
          spellcheck="false"
          aria-describedby="blog-search-status"
          aria-controls="blog-search-results"
        />
        <button
          id="blog-search-clear"
          type="button"
          class="hidden rounded-full border border-gray-200 px-3 py-1 text-sm font-medium text-gray-600 transition hover:border-gray-300 hover:text-gray-900"
          aria-label={copy.clear}
        >
          {copy.clear}
        </button>
      </div>
      <p id="blog-search-status" class="mt-3 text-sm text-gray-600" aria-live="polite">{copy.helper}</p>
    </div>
  </div>

  <div id="blog-search-results" hidden aria-live="polite"></div>
</div>

<script>
  import { bootstrapBlogSearch } from '~/components/blog/blog-search-loader';

  bootstrapBlogSearch();
</script>
