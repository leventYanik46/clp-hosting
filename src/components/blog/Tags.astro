---
import { getPermalink } from '~/utils/permalinks';

import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

export interface Props {
  tags: Post['tags'];
  class?: string;
  title?: string | undefined;
  isCategory?: boolean;
  taxonomyBasePath?: string;
}

const { tags, class: className = 'text-sm', title = undefined, isCategory = false, taxonomyBasePath } = Astro.props;
const shouldLink = taxonomyBasePath ? true : APP_BLOG?.tag?.isEnabled;
---

{
  tags && Array.isArray(tags) && (
    <>
      <>
        {title !== undefined && (
          <span class="align-super font-normal underline underline-offset-4 decoration-2 ">{title}</span>
        )}
      </>
      <ul class={className}>
        {tags.map((tag) => (
          <li class="bg-gray-100 inline-block mr-2 rtl:mr-0 rtl:ml-2 mb-2 py-0.5 px-2 lowercase font-medium">
            {!shouldLink ? (
              tag.title
            ) : (
              <a
                href={
                  taxonomyBasePath
                    ? getPermalink(`${taxonomyBasePath}/${isCategory ? 'category' : 'tag'}/${tag.slug}`, 'page')
                    : getPermalink(tag.slug, isCategory ? 'category' : 'tag')
                }
                class="text-muted hover:text-primary "
              >
                {tag.title}
              </a>
            )}
          </li>
        ))}
      </ul>
    </>
  )
}
