---
import Item from '~/components/blog/ListItem.astro';
import type { Post } from '~/types';

export interface Props {
  posts: Array<Post>;
  lang?: string;
  taxonomyBasePath?: string;
}

const { posts, lang, taxonomyBasePath } = Astro.props;
---

<ul>
  {
    posts.map((post, index) => (
      <li class="mb-12 md:mb-20">
        <Item post={post} lang={lang} taxonomyBasePath={taxonomyBasePath} isPriority={index === 0} />
      </li>
    ))
  }
</ul>
