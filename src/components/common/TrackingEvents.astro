---
import { ANALYTICS } from 'astrowind:config';

const enabled = !!ANALYTICS?.vendors?.googleAnalytics?.id;
---

{enabled && (
  <script>
    document.addEventListener('click', (event) => {
      const link = (event.target instanceof Element)
        ? event.target.closest('a[href]')
        : null;
      if (!(link instanceof HTMLAnchorElement) || typeof window.gtag !== 'function') return;

      const href = link.getAttribute('href') ?? '';

      if (link.hasAttribute('data-analytics-announcement-phone') && href.startsWith('tel:')) {
        window.gtag('event', 'phone_call_click', {
          phone_number: href.replace(/^tel:/i, ''),
          source_component: 'announcement_bar',
        });
      } else if (link.hasAttribute('data-analytics-whatsapp')) {
        window.gtag('event', 'whatsapp_click', {
          link_url: href,
          source_component: 'chat_button',
        });
      }
    });
  </script>
)}
