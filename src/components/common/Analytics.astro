---
import { ANALYTICS } from 'astrowind:config';

const gaId = ANALYTICS?.vendors?.googleAnalytics?.id;
const adsId = ANALYTICS?.vendors?.googleAds?.id;

const initScript = gaId ? `window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaId}');
${adsId ? `gtag('config', '${adsId}');` : ''}` : '';
---

{gaId && (
  <>
    <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} async />
    <script is:inline set:html={initScript} />
  </>
)}
