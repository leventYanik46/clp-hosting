---
import { Icon } from 'astro-icon/components';
import { getPermalink } from '~/utils/permalinks';
import { I18N } from 'astrowind:config';
import Button from '~/components/ui/Button.astro';
import config from '~/config/config.json';

const { textDirection } = I18N;
const { lang } = Astro.props;
const { default_language, default_language_in_subdir } = config.settings;
const needsPrefix = lang && (lang !== default_language || default_language_in_subdir);
const pathPrefix = needsPrefix ? lang : '';
const eventsPath = pathPrefix ? `${pathPrefix}/events` : 'events';
const eventsHref = getPermalink(eventsPath, 'page');

const linkTextByLang: Record<string, string> = {
  en: 'Back to Events',
  tr: 'Etkinliklere Don',
  es: 'Volver a Eventos',
  pt: 'Voltar para Eventos',
  fr: 'Retour aux evenements',
};

const backText = linkTextByLang[lang || default_language] || linkTextByLang.en;
---

<div class="mx-auto px-6 sm:px-6 max-w-3xl pt-8 md:pt-4 pb-12 md:pb-20">
  <Button variant="tertiary" class="px-3 md:px-3" href={eventsHref}>
    {
      textDirection === 'rtl' ? (
        <Icon name="tabler:chevron-right" class="w-5 h-5 mr-1 -ml-1.5 rtl:-mr-1.5 rtl:ml-1" />
      ) : (
        <Icon name="tabler:chevron-left" class="w-5 h-5 mr-1 -ml-1.5 rtl:-mr-1.5 rtl:ml-1" />
      )
    } {backText}
  </Button>
</div>
