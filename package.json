{
  "name": "@onwidget/astrowind",
  "version": "1.0.0-beta.48",
  "description": "AstroWind: A free template using Astro 4.0 and Tailwind CSS. Astro starter theme.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.12.2"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "npm run validate:seo",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "validate:seo": "node ./scripts/validate-seo.mjs",
    "migrate:seo": "node ./scripts/migrate-metadata-to-seo.mjs",
    "normalize:post-canonicals": "node ./scripts/normalize-post-canonicals.mjs",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "deploy": "netlify build && netlify deploy --prod",
    "test": "netlify build && netlify deploy"
  },
  "dependencies": {
    "@astrojs/netlify": "^6.2.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "@astrolib/analytics": "^0.6.1",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@fontsource-variable/inter": "^5.1.0",
    "astro": "^5.2.6",
    "astro-embed": "^0.7.4",
    "astro-icon": "^1.1.1",
    "decap-cms-app": "^3.6.3",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "limax": "4.1.0",
    "lodash.merge": "^4.6.2",
    "nodemailer": "^8.0.4",
    "unpic": "^3.18.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.0.8",
    "@astrojs/partytown": "^2.1.3",
    "@astrojs/tailwind": "^6.0.0",
    "@eslint/js": "^9.12.0",
    "@iconify-json/flat-color-icons": "^1.2.0",
    "@iconify-json/tabler": "^1.2.5",
    "@tailwindcss/typography": "^0.5.15",
    "@types/eslint__js": "^8.42.3",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.13",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "astro-compress": "2.4.0",
    "astro-eslint-parser": "^1.0.3",
    "baseline-browser-mapping": "^2.10.11",
    "eslint": "^9.12.0",
    "eslint-plugin-astro": "^1.2.4",
    "globals": "^15.11.0",
    "js-yaml": "^4.1.0",
    "mdast-util-to-string": "^4.0.0",
    "netlify-cli": "^24.6.2",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "0.33.5",
    "tailwind-merge": "^2.5.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "unist-util-visit": "^5.0.0"
  },
  "overrides": {
    "@netlify/build": {
      "yaml": "2.8.3"
    },
    "@netlify/build-info": {
      "yaml": "2.8.3"
    },
    "@netlify/config": {
      "yaml": "2.8.3"
    },
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "netlify-cli": {
      "yaml": "2.8.3"
    },
    "yaml-language-server": {
      "yaml": "2.8.3"
    }
  }
